{
  "schema_version": "1.0.0",
  "application": "dashhr",
  "description": "Frontend resource catalog for modules, pages, permissions, actions, entities, and workflow capabilities.",
  "permission_flag_usage": {
    "note": "canRead, canModify, canCreate, canReview and canAssign are runtime access flags returned by authorization APIs for a specific user, job role and attached resources.",
    "catalog_permissions_field": "permissions",
    "catalog_permissions_meaning": "Static required permission keys for pages/resources in this catalog"
  },
  "authorization_api_contract": {
    "purpose": "Resolve user access by job role and role-resource attachments",
    "response_shape": {
      "user": {
        "user_id": "string",
        "employee_id": "string",
        "organization_id": "string",
        "job_role_id": "string",
        "job_role_code": "string"
      },
      "resources": [
        {
          "resource_id": "string",
          "resource_code": "string",
          "resource_name": "string",
          "module": "string",
          "canRead": true,
          "canModify": false,
          "canCreate": false,
          "canReview": false,
          "canAssign": false
        }
      ]
    },
    "suggested_endpoint": {
      "method": "GET",
      "path": "/api/role-permissions/me/resources"
    },
    "mapping_from_role_resources": {
      "canCreate": "can_create OR can_manage",
      "canRead": "can_read OR can_manage",
      "canModify": "can_update OR can_delete OR can_manage",
      "canReview": "resource supports approval/review actions OR can_manage",
      "canAssign": "resource supports assignment actions OR can_manage"
    }
  },
  "defaults": {
    "access_levels": ["none", "view", "create", "update", "delete", "approve", "admin"],
    "route_guard_types": ["public", "authenticated", "admin"],
    "http_methods": ["GET", "POST", "PUT", "PATCH", "DELETE"]
  },
  "global_permissions": {
    "module": [
      "module:view",
      "module:configure",
      "module:admin"
    ],
    "page": [
      "page:view",
      "page:export",
      "page:filter"
    ],
    "resource": [
      "resource:list",
      "resource:view",
      "resource:create",
      "resource:update",
      "resource:delete",
      "resource:assign",
      "resource:approve",
      "resource:reject",
      "resource:seed",
      "resource:initialize",
      "resource:submit",
      "resource:review",
      "resource:publish",
      "resource:archive",
      "resource:download",
      "resource:upload",
      "resource:notify"
    ],
    "workflow": [
      "workflow:view",
      "workflow:create",
      "workflow:update",
      "workflow:activate",
      "workflow:deactivate",
      "workflow:approve",
      "workflow:reject"
    ]
  },
